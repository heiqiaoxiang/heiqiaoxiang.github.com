---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    company: '公司名称',
    role: '职位',
    period: '2020 - 至今',
    description: '工作描述'
  }
];

const skills = ['技能1', '技能2', '技能3'];
---

<Layout title="简历">
  <h1>简历</h1>

  <section class="section">
    <h2>关于我</h2>
    <p>个人简介...</p>
  </section>

  <section class="section">
    <h2>技能</h2>
    <div class="skills">
      {skills.map(skill => <span class="skill-tag">{skill}</span>)}
    </div>
  </section>

  <section class="section">
    <h2>经历</h2>
    {experience.map(exp => (
      <div class="experience">
        <h3>{exp.role}</h3>
        <p class="company">{exp.company} · {exp.period}</p>
        <p>{exp.description}</p>
      </div>
    ))}
  </section>

  <section class="section">
    <h2>联系方式</h2>
    <p>Email: example@email.com</p>
  </section>
</Layout>

<style>
  .section {
    margin-top: calc(var(--space-unit) * 6);
  }

  .section h2 {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0;
    margin-bottom: calc(var(--space-unit) * 3);
  }

  .skills {
    display: flex;
    gap: var(--space-unit);
    flex-wrap: wrap;
  }

  .skill-tag {
    padding: 4px 12px;
    background: var(--color-border);
    border-radius: 16px;
    font-size: 0.9rem;
  }

  .experience {
    margin-bottom: calc(var(--space-unit) * 4);
  }

  .experience h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 4px 0;
  }

  .company {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-unit);
  }
</style>
