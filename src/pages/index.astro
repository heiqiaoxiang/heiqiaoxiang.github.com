---
import Layout from '../layouts/Layout.astro';
---

<Layout title="首页">
  <section class="hero">
    <h1>你好</h1>
    <p class="intro">
      我是 XXX，一个热爱技术与设计的人。
    </p>
    <p class="intro">
      这里是我的个人空间，记录我的作品、思考和成长。
    </p>
  </section>

  <section class="section">
    <h2>最近动态</h2>
    <p>博客即将上线，敬请期待...</p>
  </section>
</Layout>

<style>
  .hero {
    margin-bottom: calc(var(--space-unit) * 8);
  }

  .intro {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 540px;
  }

  .section {
    margin-top: calc(var(--space-unit) * 6);
  }

  .section h2 {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0;
    margin-bottom: calc(var(--space-unit) * 3);
  }
</style>
