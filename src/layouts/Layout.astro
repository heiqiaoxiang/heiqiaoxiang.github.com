---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal website' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="page-transition"></div>
    <header class="header">
      <nav class="nav">
        <a href="/" class="nav-link" data-underline>首页</a>
        <a href="/portfolio" class="nav-link" data-underline>作品集</a>
        <a href="/resume" class="nav-link" data-underline>简历</a>
        <a href="/blog" class="nav-link" data-underline>博客</a>
      </nav>
    </header>
    <main class="main">
      <slot />
    </main>
    <footer class="footer">
      <p>&copy; 2024 · <a href="https://github.com/heiqiaoxiang" target="_blank" rel="noopener">GitHub</a></p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* Colors - Light */
    --color-bg: #fafafa;
    --color-text: #1a1a1a;
    --color-text-muted: #666;
    --color-accent: #3b82f6;
    --color-accent-hover: #2563eb;
    --color-border: #e5e5e5;
    --color-card: #ffffff;
    --color-card-hover: #f8f8f8;
    
    /* Typography */
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    
    /* Spacing */
    --space-unit: 8px;
    --max-width: 720px;
    
    /* Animation */
    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-bg: #09090b;
      --color-text: #fafafa;
      --color-text-muted: #a1a1aa;
      --color-accent: #60a5fa;
      --color-accent-hover: #93c5fd;
      --color-border: #27272a;
      --color-card: #18181b;
      --color-card-hover: #27272a;
    }
  }

  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-weight: 400 700;
    font-display: swap;
    src: url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    background: var(--color-bg);
    color: var(--color-text);
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    opacity: 0;
    animation: fadeIn 0.4s var(--ease-out) forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Page transition */
  .page-transition {
    position: fixed;
    inset: 0;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    animation: pageEnter 0.5s var(--ease-out) forwards;
    pointer-events: none;
    z-index: 9999;
  }

  @keyframes pageEnter {
    0% { transform: scaleX(0); }
    50% { transform: scaleX(1); }
    100% { transform: scaleX(0); transform-origin: right; }
  }

  /* Links */
  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--color-accent-hover);
  }

  /* Navigation */
  .header {
    padding: calc(var(--space-unit) * 3) calc(var(--space-unit) * 2);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    background: var(--color-bg);
    z-index: 100;
    animation: slideDown 0.5s var(--ease-out) forwards;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-100%); }
    to { opacity: 1; transform: translateY(0); }
  }

  .nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    gap: calc(var(--space-unit) * 5);
  }

  .nav-link {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    position: relative;
    padding: 4px 0;
    transition: color 0.2s ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: width 0.3s var(--ease-out);
  }

  .nav-link:hover,
  .nav-link[aria-current="page"] {
    color: var(--color-text);
  }

  .nav-link:hover::after,
  .nav-link[aria-current="page"]::after {
    width: 100%;
  }

  /* Main content */
  .main {
    flex: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: calc(var(--space-unit) * 8) calc(var(--space-unit) * 2);
    width: 100%;
  }

  /* Footer */
  .footer {
    padding: calc(var(--space-unit) * 5) calc(var(--space-unit) * 2);
    text-align: center;
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer a {
    color: var(--color-text-muted);
  }

  .footer a:hover {
    color: var(--color-accent);
  }

  /* Typography */
  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: calc(var(--space-unit) * 3);
    letter-spacing: -0.02em;
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: calc(var(--space-unit) * 6);
    margin-bottom: calc(var(--space-unit) * 3);
    color: var(--color-text);
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: var(--space-unit);
  }

  p {
    margin-bottom: calc(var(--space-unit) * 2);
    color: var(--color-text-muted);
  }

  /* Code */
  code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-border);
    padding: 2px 6px;
    border-radius: 4px;
  }

  pre {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: calc(var(--space-unit) * 2);
    overflow-x: auto;
    margin: calc(var(--space-unit) * 3) 0;
  }

  pre code {
    background: none;
    padding: 0;
  }

  /* Selection */
  ::selection {
    background: var(--color-accent);
    color: white;
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    background: var(--color-bg);
  }

  ::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--color-text-muted);
  }

  /* Focus styles */
  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Cards */
  .card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: calc(var(--space-unit) * 3);
    transition: all 0.3s var(--ease-out);
  }

  .card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  @media (prefers-color-scheme: dark) {
    .card:hover {
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    }
  }
</style>
